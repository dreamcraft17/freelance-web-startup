{
  "name": "freelance-marketplace-saas",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for a category-agnostic, geo-aware freelance marketplace SaaS platform",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "postinstall": "pnpm db:generate",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "pnpm --filter @acme/database db:generate",
    "db:migrate": "pnpm --filter @acme/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @acme/database db:migrate:deploy",
    "db:studio": "pnpm --filter @acme/database db:studio",
    "db:seed": "pnpm --filter @acme/database db:seed",
    "test:e2e": "node --test scripts/e2e-marketplace-flow.mjs"
  },
  "devDependencies": {
    "next": "^15.1.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
