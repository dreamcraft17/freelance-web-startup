{
  "name": "@acme/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PostgreSQL access via Prisma: schema, migrations, generated client",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
