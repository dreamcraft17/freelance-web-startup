{
  "name": "@acme/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Background workers: billing webhooks, notifications, indexing, quota reconciliation",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@acme/database": "workspace:*",
    "@acme/types": "workspace:*",
    "@acme/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
